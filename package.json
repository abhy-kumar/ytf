    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
